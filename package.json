{
  "name": "aaron-sanders",
  "homepage": "https://aaronlinedesign.au/",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@gsap/react": "^2.1.2",
    "gh-pages": "^6.3.0",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "perspectivejs": "^1.0.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-ga4": "^3.0.1",
    "react-helmet-async": "^3.0.0",
    "react-leaflet": "^5.0.0",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^7.14.2",
    "react-toastify": "^11.1.0",
    "swiper": "^12.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "react-snap": "^1.23.0",
    "sass": "^1.99.0",
    "vite": "^8.0.10"
  },
  "reactSnap": {
    "source": "dist",
    "skipThirdPartyRequests": true,
    "include": [
      "/",
      "/projects",
      "/services/web-services",
      "/services/logo-design",
      "/services/photography",
      "/contact",
      "/privacy",
      "/pricing",
      "/web-designer-brisbane"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  }
}
